# ╔══════════════════════════════════════════════════════════════════╗
# ║  StudyOS — AI-Powered LMS                                       ║
# ║  Root .gitignore — covers backend (Python) + frontend (Next.js) ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── OS / Editor ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/settings.json
.idea/

# ── Environment & Secrets ────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.local.example
*.pem
*.key
*.cert

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.log

# ── Node.js / Next.js ────────────────────────────────────────────────
node_modules/
.next/
out/
.nuxt/
.output/
dist/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vercel
.turbo

# ── Docker ───────────────────────────────────────────────────────────
# Don't ignore compose files — they are committed
# But ignore volume data and override files
docker-compose.override.yml
.docker/

# ── Database / Migrations ────────────────────────────────────────────
# Keep migration versions — they are source code
# Ignore any local dump files
*.sql.gz
*.dump
pgdata/
redisdata/

# ── Ollama ───────────────────────────────────────────────────────────
ollama_models/

# ── Test / Coverage ──────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/

# ── Misc ─────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
SKILLS.md
